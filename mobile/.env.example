# Supabase (same project as Next.js web app)
# Copy from Supabase Dashboard → Settings → API (Project URL + anon public key).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Deployed Next.js origin (no trailing slash) — Prisma API + Whisper
EXPO_PUBLIC_API_URL=https://your-app.vercel.app

# You can instead use the repo root `.env` / `.env.local` with NEXT_PUBLIC_SUPABASE_*
# and NEXT_PUBLIC_API_URL — mobile/app.config.js maps them to EXPO_PUBLIC_*.
# After any env change, restart Metro: npx expo start -c
