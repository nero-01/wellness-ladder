# Supabase (Auth + API URL for Edge Functions proxy)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Must be the anon public JWT from Supabase (starts with eyJ). Publishable keys (sb_…) won’t work for sign-in.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Optional: canonical site URL for email confirmation links (must match Supabase Auth → Redirect URLs, e.g. https://yourapp.com/auth/callback). If unset, the browser origin is used.
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Mock auth: Next.js web (lib/auth.tsx) and Expo (via mobile/app.config.js → EXPO_PUBLIC_USE_MOCK_AUTH).
# Web only: use client mock auth (lib/auth.tsx) even when Supabase vars are set.
# Use while testing UI before real users exist, or when anon key / users are not ready.
# NEXT_PUBLIC_USE_MOCK_AUTH=true

# Web mock mode only — optional fixed login (both required if you use them):
# NEXT_PUBLIC_MOCK_DEV_EMAIL=demo@wellness.app
# NEXT_PUBLIC_MOCK_DEV_PASSWORD=your-local-password

# Prisma: use the Postgres connection string from Supabase (Settings → Database).
# Use the "direct" or "session" connection for migrations if you use connection pooling.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Server-only: protect cron route (Vercel Cron sends this header if configured)
CRON_SECRET=generate_a_long_random_string

# Optional: real Whisper transcription in POST /api/voice/transcribe
OPENAI_API_KEY=

# ElevenLabs TTS for mobile guidance (POST /api/voice/elevenlabs — key stays server-side only)
# Get key from ElevenLabs → Profile. Default voice matches README “Voice reference”.
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=pjcYQlDFKMbcOUp6F5GD
# Optional: ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Pro: show bonus strip on task completion (web + Expo). Same value can set EXPO_PUBLIC_WELLNESS_PRO in mobile/.env.
# NEXT_PUBLIC_WELLNESS_PRO=true
#
# Local dev only: allow TTS without a logged-in user (401 otherwise with mock auth).
# Never set in production. See README “Voice guidance (troubleshooting)”.
# ELEVENLABS_TTS_ALLOW_NO_AUTH_IN_DEV=true
