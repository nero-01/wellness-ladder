# Supabase (Auth + API URL for Edge Functions proxy)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Web only: use client mock auth (lib/auth.tsx) even when Supabase vars are set.
# Use while testing UI before real users exist, or when anon key / users are not ready.
# NEXT_PUBLIC_USE_MOCK_AUTH=true

# Web mock mode only — optional fixed login (both required if you use them):
# NEXT_PUBLIC_MOCK_DEV_EMAIL=demo@wellness.app
# NEXT_PUBLIC_MOCK_DEV_PASSWORD=your-local-password

# Prisma: use the Postgres connection string from Supabase (Settings → Database).
# Use the "direct" or "session" connection for migrations if you use connection pooling.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Server-only: protect cron route (Vercel Cron sends this header if configured)
CRON_SECRET=generate_a_long_random_string

# Optional: real Whisper transcription in POST /api/voice/transcribe
OPENAI_API_KEY=
